generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OutboxStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

enum AuthStatus {
  APPROVED
  DECLINED
  CAPTURED
  REVERSED
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

enum WalletStatus {
  ACTIVE
  BLOCKED
  CLOSED
}

model OutboxEvent {
  id          String       @id @default(uuid())
  eventType   String
  aggregateId String
  payload     Json
  status      OutboxStatus @default(PENDING)
  lockedUntil DateTime?
  attempts    Int          @default(0)
  lastError   String?
  createdAt   DateTime     @default(now())
  sentAt      DateTime?

  @@index([status, createdAt])
  @@index([lockedUntil])
  @@index([eventType])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallets Wallet[]
}

model Wallet {
  id        String       @id @default(uuid())
  userId    String
  balance   Int          @default(0)
  currency  String
  country   String?
  status    WalletStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user   User          @relation(fields: [userId], references: [id])
  cards  Card[]
  ledger LedgerEntry[]

  @@index([userId])
}

model Card {
  id        String   @id @default(uuid())
  walletId  String
  balance   Int
  currency  String
  createdAt DateTime @default(now())

  wallet Wallet          @relation(fields: [walletId], references: [id])
  auths  Authorization[]

  @@index([walletId])
}

model Authorization {
  id             String     @id @default(uuid())
  idempotencyKey String     @unique
  cardId         String
  merchantId     String
  amount         Int
  currency       String
  status         AuthStatus
  createdAt      DateTime   @default(now())

  card          Card          @relation(fields: [cardId], references: [id])
  capture       Capture?
  reversal      Reversal?
  ledgerEntries LedgerEntry[]

  @@index([cardId])
  @@index([merchantId])
  @@index([status])
}

model Capture {
  id              String   @id @default(uuid())
  authorizationId String   @unique
  idempotencyKey  String   @unique
  amount          Int
  createdAt       DateTime @default(now())

  authorization Authorization @relation(fields: [authorizationId], references: [id])
}

model Reversal {
  id              String   @id @default(uuid())
  authorizationId String   @unique
  idempotencyKey  String   @unique
  amount          Int
  createdAt       DateTime @default(now())

  authorization Authorization @relation(fields: [authorizationId], references: [id])
}

model LedgerEntry {
  id              String          @id @default(uuid())
  walletId        String
  authorizationId String?
  type            LedgerEntryType
  amount          Int
  currency        String
  description     String?
  createdAt       DateTime        @default(now())

  wallet        Wallet         @relation(fields: [walletId], references: [id])
  authorization Authorization? @relation(fields: [authorizationId], references: [id])

  @@index([walletId, createdAt])
  @@index([authorizationId])
  @@index([type])
}

model BlockedMerchant {
  id         String   @id @default(uuid())
  merchantId String   @unique
  reason     String?
  active     Boolean  @default(true)
  createAt   DateTime @default(now())
}

model BlockedCountry {
  id          String   @id @default(uuid())
  countryCode String   @unique
  reason      String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}
